@@ -0,0 +1,86 @@
+// Copyright 2026 Alex313031
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#ifndef MCLOUD_EASTER_EGGS_H_
+#define MCLOUD_EASTER_EGGS_H_
+
+#include "base/memory/ref_counted_memory.h"
+#include "chrome/browser/profiles/profile.h"
+#include "chrome/common/webui_url_constants.h"
+#include "content/public/browser/url_data_source.h"
+#include "content/public/browser/web_ui.h"
+#include "content/public/browser/web_ui_controller.h"
+#include "content/public/browser/webui_config.h"
+#include "services/network/public/mojom/content_security_policy.mojom.h"
+
+class Mcloud BrowserDataSource : public content::URLDataSource {
+ public:
+  Mcloud BrowserDataSource() {}
+  Mcloud BrowserDataSource(const Mcloud BrowserDataSource&) = delete;
+  Mcloud BrowserDataSource& operator=(const Mcloud BrowserDataSource&) = delete;
+  std::string GetSource() override;
+  std::string GetMimeType(const GURL& url) override;
+  std::string GetContentSecurityPolicy(network::mojom::CSPDirectiveName directive) override;
+  void StartDataRequest(const GURL& url,
+                        const content::WebContents::Getter& wc_getter,
+                        GotDataCallback callback) override;
+};
+
+std::string Mcloud BrowserDataSource::GetSource() { return "eggs"; }
+std::string Mcloud BrowserDataSource::GetMimeType(const GURL& url) { return "text/html"; }
+std::string Mcloud BrowserDataSource::GetContentSecurityPolicy(network::mojom::CSPDirectiveName directive) {
+  if (directive == network::mojom::CSPDirectiveName::ScriptSrc)
+    return "script-src 'unsafe-inline'";
+  return std::string();
+}
+void Mcloud BrowserDataSource::StartDataRequest(const GURL& url,
+                      const content::WebContents::Getter& wc_getter,
+                      GotDataCallback callback) {
+  std::string source = R"(
+    <html>
+    <head>
+      <title>Mcloud Browser Easter Eggs</title>
+      <meta name="color-scheme" content="light dark">
+      <meta name="viewport" content="width=device-width, initial-scale=1">
+      <link rel="shortcut icon" type="image/x-icon" href="chrome://theme/current-channel-logo@2x">
+    <style>
+      @import url(chrome://resources/css/text_defaults_md.css);
+      body { text-align: center; align-content: center; max-width: 75%; margin: auto;}
+      img { max-width: 75%; height: auto; }
+    </style>
+    </head>
+    <body>
+      <h2><u>Mcloud Browser Easter Eggs WebUI Page</u></h3>
+      <hr>
+      <p>
+        <img src="chrome://theme/IDR_PRODUCT_MCLOUD_ELEMENT">
+        <hr>
+        <img src="chrome://theme/IDR_PRODUCT_MCLOUD_ATOMIC">
+        <img src="chrome://theme/IDR_PRODUCT_CHROMIUM_QUESTION">
+        <img src="chrome://theme/IDR_PRODUCT_MCLOUD_GUY">
+        <img src="chrome://theme/IDR_PRODUCT_CHROMIUM_BLANK">
+        <img src="chrome://theme/IDR_PRODUCT_AI_CHROME">
+      </p>
+    </body>
+    </html>
+  )";
+  std::move(callback).Run(base::MakeRefCounted<base::RefCountedString>(std::move(source)));
+}
+
+class Mcloud BrowserWebUILoad;
+class Mcloud BrowserWebUILoadUIConfig : public content::DefaultWebUIConfig<Mcloud BrowserWebUILoad> {
+  public:
+   Mcloud BrowserWebUILoadUIConfig() : DefaultWebUIConfig("chrome", chrome::kChromeUIEggsHost) {}
+};
+
+class Mcloud BrowserWebUILoad : public content::WebUIController {
+ public:
+  Mcloud BrowserWebUILoad(content::WebUI* web_ui) : content::WebUIController(web_ui) {
+    content::URLDataSource::Add(Profile::FromWebUI(web_ui), std::make_unique<Mcloud BrowserDataSource>());
+  }
+  Mcloud BrowserWebUILoad(const Mcloud BrowserWebUILoad&) = delete;
+  Mcloud BrowserWebUILoad& operator=(const Mcloud BrowserWebUILoad&) = delete;
+};
+
+#endif  // MCLOUD_EASTER_EGGS_H_
